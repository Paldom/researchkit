# researchkit provider API keys — copy to .env and fill in what you have.
# One key is enough to try it: providers without keys are skipped gracefully.

# Providers (default set first: openai, gemini, grok, perplexity run without
# --providers; the rest are opt-in via --providers <name> …)
OPENAI_API_KEY=
GEMINI_API_KEY=          # or GOOGLE_API_KEY
XAI_API_KEY=             # Grok
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
GITHUB_TOKEN=            # GitHub code/issue search
GLM_API_KEY=             # Z.ai (also accepts ZAI_API_KEY / ZHIPUAI_API_KEY)
KIMI_API_KEY=            # Moonshot AI (also accepts MOONSHOT_API_KEY)
BRAVE_API_KEY=           # independent-index search (cheap tier requires public attribution)
EXA_API_KEY=             # provider AND the built-in site-research connector
# claude needs no key here: it runs on the Claude Code CLI (subscription auth)
# openalex is keyless; OPENALEX_MAILTO= (optional) joins its polite pool

# Plugins (external site-research connectors bring their own keys)

# Optional overrides
# KIMI_BASE_URL=         # https://api.moonshot.cn/v1 (China platform) or
#                        # https://api.kimi.com/coding/v1 (Kimi Code Console key)
# OPENALEX_MAILTO=

# Server (optional overrides)
# RESEARCHKIT_HOST=127.0.0.1
# RESEARCHKIT_PORT=8000
# RESEARCHKIT_AUTH_TOKEN=   # required to bind non-loopback hosts
